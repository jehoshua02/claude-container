# Copy this file to .env and fill in your values

# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Git identity — required if you want Claude to make commits
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@example.com

# SSH private key for private repo access (optional)
# Paste the full contents of your private key on one line, with literal \n for newlines:
# SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\nAAA...\n-----END OPENSSH PRIVATE KEY-----
